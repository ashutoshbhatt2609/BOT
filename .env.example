# Copy this file to .env and fill in your values

# Your Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Timezone for reminders and reports (e.g., Asia/Kolkata)
TIMEZONE=Asia/Kolkata

# Telegram Chat ID of the Core Leadership group (for weekly reports & announcements)
# Get it by adding @userinfobot to your group
CORE_GROUP_CHAT_ID=-100xxxxxxxxxx

# Path to SQLite database file
DB_PATH=rotaract.db
