# ─── Local Development ────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather_here

# Timezone for reminders/reports (Asia/Kolkata = IST)
TIMEZONE=Asia/Kolkata

# Optional: Telegram Group ID of Core Leadership chat
# Get it by adding @userinfobot to your group
CORE_GROUP_CHAT_ID=0

# SQLite database path (local only — Railway uses ephemeral storage)
DB_PATH=rotaract.db

# ─── Production / Railway Webhook ─────────────────────────────────────────────
# Set WEBHOOK_URL to your Railway public URL (no trailing slash)
# Example: https://rotaract-bot-production.up.railway.app
# Leave EMPTY for local long-polling mode
WEBHOOK_URL=

# Railway injects PORT automatically — don't set this locally
# PORT=8443

# Optional webhook secret token for extra security
WEBHOOK_SECRET=
