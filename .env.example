# ─── Local Development ────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather_here

# Timezone for reminders/reports (Asia/Kolkata = IST)
TIMEZONE=Asia/Kolkata

# Optional: Telegram Group ID of Core Leadership chat
# Get it by adding @userinfobot to your group
CORE_GROUP_CHAT_ID=0

# ─── Admin Auto-Bootstrap (Crucial for Render free tier) ──────────────
# Sets you as Core admin on every startup (since SQLite resets on deploy)
ADMIN_TELEGRAM_ID=
ADMIN_NAME=Admin

# SQLite database path (local only — Railway uses ephemeral storage)
DB_PATH=rotaract.db

# ─── Production / Render Webhook ──────────────────────────────────────────────
# Set WEBHOOK_URL to your Render public URL (no trailing slash)
# Render URL format: https://<service-name>.onrender.com
# Leave EMPTY for local long-polling mode
WEBHOOK_URL=

# Render injects PORT automatically — don't set this locally
# PORT=10000

# Optional: random secret token to validate webhook authenticity
# Render can auto-generate this (see render.yaml → generateValue: true)
WEBHOOK_SECRET=
